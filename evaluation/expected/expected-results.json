{
  "facebook.csv": {
    "min_valid_records": 3,
    "expected_mappings": {
      "full_name": "name",
      "email": "email",
      "phone_number": "mobile_without_country_code"
    }
  },
  "real-estate.csv": {
    "min_valid_records": 3,
    "expected_mappings": {
      "Customer": "name",
      "Mail ID": "email",
      "Contact 1": "mobile_without_country_code"
    }
  },
  "ambiguous.csv": {
    "min_valid_records": 2,
    "row_expectations": [
      { "row": 1, "email": "john@example.com", "crm_status": "GOOD_LEAD_FOLLOW_UP" },
      { "row": 2, "mobile": "9876543210", "crm_status": "DID_NOT_CONNECT" }
    ]
  },
  "invalid-records.csv": {
    "min_valid_records": 2,
    "min_skipped_records": 3,
    "total_rows": 5
  },
  "messy.csv": {
    "min_valid_records": 2,
    "min_skipped_records": 3,
    "total_rows": 5,
    "requires_roundtrip": true,
    "row_expectations": [
      { "row": 1, "email": "john.doe@example.com" },
      { "row": 2, "expected_skip": true, "reason": "no contact column value" },
      { "row": 3, "mobile": "9876543210", "country_code": "+91" },
      { "row": 4, "expected_skip": true, "reason": "no contact column value" },
      { "row": 5, "expected_skip": true, "reason": "invalid email in contact column" }
    ]
  }
}
